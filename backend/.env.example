# ========================================
# Lily Cafe POS System - Backend Configuration
# Copy this file to .env and update the values
# ========================================

# Security
SECRET_KEY=your-secret-key-change-in-production
TOKEN_EXPIRY_HOURS=24

# Admin Credentials (access to all features EXCEPT analytics)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Owner Credentials (full access including analytics)
OWNER_USERNAME=owner
OWNER_PASSWORD=owner123

# Restaurant Configuration
MAX_TABLES=15
GST_RATE=18
TIMEZONE=Asia/Kolkata

# Restaurant Details
RESTAURANT_NAME="Lily Cafe by Mary's Kitchen"
RESTAURANT_ADDRESS_LINE1=Shop 123, Main Street
RESTAURANT_ADDRESS_LINE2=City, State - 123456
RESTAURANT_PHONE=+91-1234567890
RESTAURANT_EMAIL=info@lilycafe.com
RESTAURANT_GSTIN=29ABCDE1234F1Z5
RESTAURANT_FSSAI=29ABCDE1234F1Z5
RESTAURANT_LOGO_PATH=

# Receipt Configuration
RECEIPT_PAPER_SIZE=80mm
GOOGLE_REVIEW_URL=https://g.page/r/your-business-review
FEEDBACK_FORM_URL=https://forms.gle/your-feedback-form

# Thermal Printer Configuration
PRINTER_ENABLED=false
PRINTER_TYPE=
PRINTER_NAME=
PRINTER_VENDOR_ID=
PRINTER_PRODUCT_ID=
PRINTER_PORT=
PRINTER_BAUDRATE=9600

# Owner Password Hash (for cash counter verification - separate from login)
OWNER_PASSWORD_HASH=$2b$12$EixZaYVK1fsbw1ZfbX3OXePaWxn96p36WQoeG6Lruj3vjPGga31lW

# Database
DATABASE_URL=sqlite:///./restaurant.db

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# ========================================
# Email / SMTP Configuration (Inventory Reports)
# ========================================

# Master switch - set to true to enable email reports on daily count save
SMTP_ENABLED=false

# SMTP server settings (defaults to Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Gmail credentials (use an App Password, not your account password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Sender email (usually same as SMTP_USERNAME)
SMTP_SENDER_EMAIL=your-email@gmail.com

# Comma-separated list of recipient emails for inventory reports
INVENTORY_REPORT_EMAILS=owner@example.com,manager@example.com

# ========================================
# Analytics & Thesys C1 Configuration
# ========================================

# Thesys C1 API Key
# Get your API key from https://thesys.dev
THESYS_API_KEY=your-thesys-api-key-here
